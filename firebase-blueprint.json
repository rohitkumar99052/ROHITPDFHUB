{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "history": {
      "title": "History",
      "description": "User's PDF processing history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "toolId": { "type": "string" },
        "toolName": { "type": "string" },
        "fileName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "toolId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile document"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "history",
      "description": "User's processing history"
    }
  }
}
